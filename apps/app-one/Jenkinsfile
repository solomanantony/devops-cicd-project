pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID     = credentials('AWS_ACCOUNT_ID')
        AWS_REGION         = credentials('AWS_REGION')
        EKS_CLUSTER_NAME   = credentials('EKS_CLUSTER_NAME')
        SLACK_WEBHOOK_URL  = credentials('SLACK_WEBHOOK_URL')
        APP_NAME           = 'user-service'
        ECR_REPO           = 'user-service'
        NAMESPACE          = 'apps'
        IMAGE_TAG          = "${env.GIT_COMMIT}"
        ECR_URL            = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        FULL_IMAGE         = "${ECR_URL}/${ECR_REPO}:${IMAGE_TAG}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Checking out source code..."
                checkout scm
            }
        }

        stage('Run Tests') {
            steps {
                echo "Running unit tests..."
                dir('apps/app-one') {
                    sh '''
                        pip3 install -r requirements.txt
                        pip3 install pytest
                        python3 -m pytest tests/ -v || echo "No tests directory found, skipping"
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Building Docker image: ${FULL_IMAGE}"
                dir('apps/app-one') {
                    sh "docker build -t ${FULL_IMAGE} ."
                    sh "docker tag ${FULL_IMAGE} ${ECR_URL}/${ECR_REPO}:latest"
                }
            }
        }

        stage('Trivy Security Scan') {
            steps {
                echo "Running Trivy vulnerability scan..."
                sh '''
                    trivy image \
                        --exit-code 1 \
                        --severity CRITICAL,HIGH \
                        --ignore-unfixed \
                        --no-progress \
                        ${FULL_IMAGE}
                '''
            }
            post {
                failure {
                    echo "Trivy scan found CRITICAL/HIGH vulnerabilities — blocking deployment"
                    sh '''
                        curl -X POST ${SLACK_WEBHOOK_URL} \
                            -H 'Content-type: application/json' \
                            --data "{\"text\": \"🚨 *${APP_NAME}* — Trivy scan FAILED! Critical vulnerabilities found.\nBuild: ${BUILD_URL}\"}"
                    '''
                }
            }
        }

        stage('Push to ECR') {
            steps {
                echo "Pushing image to ECR..."
                sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                        docker login --username AWS --password-stdin ${ECR_URL}

                    docker push ${FULL_IMAGE}
                    docker push ${ECR_URL}/${ECR_REPO}:latest
                '''
            }
        }

        stage('Deploy to EKS') {
            steps {
                echo "Deploying to EKS cluster: ${EKS_CLUSTER_NAME}"
                sh '''
                    aws eks update-kubeconfig \
                        --region ${AWS_REGION} \
                        --name ${EKS_CLUSTER_NAME}

                    kubectl get nodes

                    # Apply namespace (idempotent — safe to run every time)
                    kubectl apply -f k8s/namespace.yaml

                    # Inject the real image tag into the deployment YAML
                    sed -i "s|IMAGE_PLACEHOLDER|${FULL_IMAGE}|g" k8s/app-one/deployment.yaml
                    sed -i "s|IMAGE_TAG_PLACEHOLDER|${IMAGE_TAG}|g" k8s/app-one/deployment.yaml

                    # Apply all manifests for app-one
                    kubectl apply -f k8s/app-one/

                    echo "Manifests applied. Waiting for rollout..."
                '''
            }
        }

        stage('Verify Rollout') {
            steps {
                echo "Verifying deployment rollout..."
                sh '''
                    kubectl rollout status deployment/${APP_NAME} \
                        -n ${NAMESPACE} \
                        --timeout=3m

                    echo "--- Running Pods ---"
                    kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME}

                    echo "--- Services ---"
                    kubectl get svc -n ${NAMESPACE}
                '''
            }
        }
    }

    post {
        success {
            echo "Deployment successful!"
            sh '''
                curl -X POST ${SLACK_WEBHOOK_URL} \
                    -H 'Content-type: application/json' \
                    --data "{\"text\": \"✅ *${APP_NAME}* deployed successfully!\nBuild: #${BUILD_NUMBER}\nCommit: ${GIT_COMMIT}\"}"
            '''
        }

        failure {
            echo "Deployment failed — attempting rollback"
            sh '''
                aws eks update-kubeconfig \
                    --region ${AWS_REGION} \
                    --name ${EKS_CLUSTER_NAME} || true

                # Rollback to previous ReplicaSet
                kubectl rollout undo deployment/${APP_NAME} -n ${NAMESPACE} || true

                curl -X POST ${SLACK_WEBHOOK_URL} \
                    -H 'Content-type: application/json' \
                    --data "{\"text\": \"❌ *${APP_NAME}* deployment FAILED & rolled back!\nBuild: #${BUILD_NUMBER}\nCommit: ${GIT_COMMIT}\nCheck: ${BUILD_URL}\"}"
            '''
        }

        always {
            echo "Cleaning up local Docker images..."
            sh "docker rmi ${FULL_IMAGE} || true"
            sh "docker rmi ${ECR_URL}/${ECR_REPO}:latest || true"
        }
    }
}